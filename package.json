{
  "name": "tiktok-live-viewer",
  "version": "1.0.0",
  "description": "Visualiseur de chat, statistiques et cadeaux pour les lives TikTok",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "pack": "electron-builder --dir",
    "release": "electron-builder --win --publish always"
  },
  "keywords": [
    "tiktok",
    "live",
    "chat",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.benjamin.tiktokliveviewer",
    "productName": "TikTok Live Viewer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "TikTokLiveViewer-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "TikTok Live Viewer",
      "artifactName": "TikTokLiveViewer-Setup-${version}.exe"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Zeeroz",
        "repo": "TiktokChatReader"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "tiktok-live-connector": "^2.4.0"
  },
  "devDependencies": {
    "electron": "^39.0.0",
    "electron-builder": "^25.1.8"
  }
}
